":"api/tags/git.json"}],"author":{"name":"Wu-Yikun","slug":"blog-author","avatar":"https://cdn.jsdelivr.net/gh/Wu-yikun/OSS/PicGo/202310141350483.jpg","link":"/","description":"<b>英特纳雄耐尔一定会实现！</b>","socials":{"github":"https://github.com/Wu-yikun","twitter":"","stackoverflow":"https://stackoverflow.com/users/16805680/wu-yikun","wechat":"","qq":"","weibo":"","zhihu":"https://www.zhihu.com/people/crush-33-16-25","csdn":"https://blog.csdn.net/qq_46221929?type=blog","juejin":"https://juejin.cn/user/1654082381026734","customs":{}}}}}